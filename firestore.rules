rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Public reads, admin writes for website content collections.
    match /lab_overview/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /team/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /interns/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /publications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Anyone can submit; only admins can read and update.
    match /applications/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# Used for internship application email delivery.
# Configure a Gmail account with an App Password.
GMAIL_USER=sender-account@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Local admin login (used by /godmode page)
# Keep real values only in .env.local (ignored by git)
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_PASSWORD=

# Optional. Defaults to jeevangowda1622@gmail.com when omitted.
GMAIL_TO=jeevangowda1622@gmail.com
